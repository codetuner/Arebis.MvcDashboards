@model IndexModel
@{
    ViewBag.Title = "Task Definitions";
}

<h1>Task Definitions</h1>

<form class="card p-3 bg-white onchange-submit" action="@Url.Action("Index")" method="get" history="replace" sub-target="#subTarget">

    <div class="d-flex justify-content-between">
        @if (Model.UserIsAdmin)
        {
            <a href="@Url.Action("New")" class="btn btn-primary" onkeydown-click="+"><i class="spinner fas fa-solid fa-plus"></i> New</a>
        }
        <div class="flex-grow-1"></div>
        @if (Model.ProcessRoles.Count > 0)
        {
            <div class="ms-2">
                <select class="form-select auto-width" asp-for="ProcessRole" asp-items="Model.ProcessRoles"><option value="">All roles</option></select>
            </div>
        }
        <div class="ms-2">
            <input type="search" class="form-control oninput-change" asp-for="Query" style="max-width: 280px;" autocomplete="off" placeholder="Search" />
        </div>
        @if (Model.ProcessRoles.Count > 0)
        {
            <div class="ms-2">
                <a href="@Url.Action("Index")" history="replace" class="btn btn-light" title="Clear filter"><i class="spinner fas fa-solid fa-eraser"></i></a>
            </div>
        }
    </div>

    <div id="subTarget">

        <div class="overlay" hidden></div>

        <div class="table-responsive">
            <table class="table table-hover mt-3">
                <thead>
                    <tr>
                        <th class="d-none onchange-nosubmit"><input type="checkbox" ifchecked-check="<table|>tbody input[type=checkbox]" ifunchecked-uncheck="<table|>tbody input[type=checkbox]" /></th>
                        <th asp-order="@Model.Order" width="5%">Id</th>
                        <th asp-order="@Model.Order" width="30%">Name</th>
                        <th asp-order="@Model.Order" width="15%" field-name="ProcessRole">Process Role</th>
                        <th asp-order="@Model.Order" width="7%" field-name="IsActive">Active</th>
                        <th asp-order="@Model.Order" width="17%" field-name="LastRun.UtcTimeStarted">Last Run</th>
                        <th asp-order="@Model.Order" width="12%" field-name="NextRun.UtcTimeToExecute">Next Run</th>
                        <th width="14%"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        var tdstyle = (item.SucceededLastRun == false) ? "background-color: var(--bs-danger-bg-subtle)" : null;
                        var tdclass = (!item.IsActive) ? "x-text-dimmed" : null;
                        <tr>
                            <td style="@tdstyle" class="d-none onchange-nosubmit" onclick-propagate="off"><input type="checkbox" /></td>
                            <td style="@tdstyle">@item.Id</td>
                            <td style="@tdstyle" class="@tdclass">
                                <strong>@(item.Name)</strong>
                            </td>
                            <td style="@tdstyle" class="@tdclass">@item.ProcessRole</td>
                            <td style="@tdstyle" class="@tdclass">@Html.Raw(item.IsActive ? "<i class=\"fa fa-check\"></i>" : "")</td>
                            <td style="@tdstyle" class="@tdclass">
                                @if (item.UtcTimeLastRun == null)
                                {
                                    <text>-</text>
                                }
                                else if (item.IsRunningLastRun == true)
                                {
                                    <span>
                                        <i class="fas fa-solid fa-running"></i>
                                        <span class="x-no-wrap x-datetime-utc-local">@(item.UtcTimeLastRun?.ToString("u"))</span>
                                        <span class="d-none d-xxl-inline">
                                            <i class="ms-1 fa-solid fa-stopwatch" title="duration"></i>
                                            <span>@(item.DuractionLastRun?.ToString("hh\\:mm\\:ss"))</span>
                                        </span>
                                    </span>
                                }
                                else if (item.SucceededLastRun == true)
                                {
                                    <span class="x-no-wrap">
                                        <i class="far fa-calendar-check"></i>
                                        <span class="x-datetime-utc-local">@(item.UtcTimeLastRun?.ToString("u"))</span>
                                        <span class="d-none d-xxl-inline">
                                            <i class="ms-1 fa-solid fa-stopwatch" title="duration"></i>
                                            <span>@(item.DuractionLastRun?.ToString("hh\\:mm\\:ss"))</span>
                                        </span>
                                    </span>
                                }
                                else
                                {
                                    <span class="x-no-wrap">
                                        <i class="fas fa-solid fa-calendar-times"></i>
                                        <span class="x-datetime-utc-local">@(item.UtcTimeLastRun?.ToString("u"))</span>
                                        <span class="d-none d-xxl-inline">
                                            <i class="ms-1 fa-solid fa-stopwatch" title="duration"></i>
                                            <span>@(item.DuractionLastRun?.ToString("hh\\:mm\\:ss"))</span>
                                        </span>
                                    </span>
                                }
                            </td>
                            <td style="@tdstyle" class="@tdclass">
                                @if (item.UtcTimeNextRun == null)
                                {
                                    <text>-</text>
                                }
                                else
                                {
                                    <span class="x-no-wrap">
                                        <i class="far fa-calendar"></i>
                                        <span class="x-datetime-utc-local">@(item.UtcTimeNextRun?.ToString("u"))</span>
                                    </span>
                                }
                            </td>
                            <td style="@tdstyle" class="@tdclass">
                                <span class="x-no-wrap float-end">
                                    <a class="btn btn-link btn-sm pt-0" href="@Url.Action("Index", "Task", new { definitionId = item.Id })" title="List all"><i class="fa-solid fa-list-check"></i></a>
                                    <a class="btn btn-link btn-sm pt-0" href="@Url.Action("New", "Task", new { definitionId = item.Id })" title="New task"><i class="spinner fas fa-solid fa-plus"></i></a>
                                    <a class="btn btn-link btn-sm pt-0" href="@Url.Action("Edit", new { id = item.Id })" title="Edit definition"><i class="fa-solid fa-pen"></i></a>
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <pagesize-select asp-for="PageSize" class="form-select auto-width float-end"></pagesize-select>
        <pagination-nav asp-for="Page" max="Model.MaxPage" keyboard="true" />

    </div>

</form>