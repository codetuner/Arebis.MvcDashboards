@model EditModel
@{
    ViewBag.Title = "Request Log Detail";
    var item = Model.Item;
}

<div class="mt-3 mb-3">
    <a href="history:back" class="btn btn-secondary onback-allowclose" onkeydown-click="ArrowLeft"><i class="fas fa-solid fa-angle-left"></i> Back</a>
    <div class="float-end">
        <a class="btn-link link-secondary" href="@Url.Action("CreateIgnoreRule", null, new { Model.Item.Id })">Create ignore rule</a>
    </div>
</div>

<div class="mt-4 mb-1">
    <span class="float-end">
        Trace identifier: <b>@item.TraceIdentifier</b>
    </span>
    <b class="x-datetime-utc-local">@(item.Timestamp.ToString("u"))</b> - (<span class="x-datetime-utc">@(item.Timestamp.ToString("u"))</span> UTC)
</div>
<div class="mb-1" style="overflow: hidden; white-space: nowrap; text-overflow: ellipsis;">
    <font size="6">
        <span class="float-end">
            <partial name="Bookmark" model="item" />
        </span>
        @Html.Raw(item.Aspect?.HtmlIcon)
        <b>@(item.Message ?? item.AspectName)</b>
    </font>
</div>
<div class="mb-1">
    <span class="float-end">
        <b>@item.DurationMs.ToString("#,##0")</b> ms
    </span>
    @if (item.StatusCode >= 500)
    {<span class="badge rounded-pill bg-danger">@item.StatusCode</span>}
else if (item.StatusCode >= 400)
{<span class="badge rounded-pill bg-warning">@item.StatusCode</span>}
else
{<span class="badge rounded-pill bg-success">@item.StatusCode</span>}
    <small>@item.Method</small>
    <b><a href="@(item.Request.ContainsKey("Header: cf-visitor") ? item.Request["Header: cf-visitor"].Contains("https") ? "https:" : "http:" : item.Request.ContainsKey("Scheme") ? item.Request["Scheme"] + ":" : "")//@(item.Request.ContainsKey("Header: Host") ? item.Request["Header: Host"] : "")@(item.Url)" target="_blank">@(item.Url)</a><button class="btn btn-light btn-sm" onclick-copytext="@(item.Request.ContainsKey("Header: cf-visitor") ? item.Request["Header: cf-visitor"].Contains("https") ? "https:" : "http:" : item.Request.ContainsKey("Scheme") ? item.Request["Scheme"] + ":" : "")//@(item.Request.ContainsKey("Header: Host") ? item.Request["Header: Host"] : "")@(item.Url)" title="Copy to clipboard"><i class="far fa-clipboard spinner"></i></button></b>
</div>
<div class="mb-1">
    Application Name: <b>@item.ApplicationName</b>
</div>
<div class="mb-3">
    Host Name: <b>@item.Host</b>
</div>

@if (item.StatusCode == 400 && (item.Method == "POST" || item.Method == "PUT"))
{
    <div class="alert alert-info">
        <strong>Hint: A status 400 on a POST or PUT request can indicate a Forgery Token issue.</strong>
    </div>
}

@if (!String.IsNullOrEmpty(item.Type))
{
    <div class="card mb-3">
        <div class="card-body">
            <span id="typeAndMessage"><strong>@item.Type</strong>@if (!String.IsNullOrWhiteSpace(item.Message))
            {<text>: <span>@item.Message <button class="btn btn-light btn-sm" onclick-copyinnertext="#typeAndMessage" title="Copy to clipboard"><i class="far fa-clipboard spinner"></i></button></span></text>}</span>
        </div>
    </div>
}

@if (!String.IsNullOrWhiteSpace(item.Details))
{
    <div class="card mb-3">
        <div class="card-body">
            <h3>Details: <button class="btn btn-light btn-sm" onclick-copyinnertext="#details" title="Copy to clipboard"><i class="far fa-clipboard spinner"></i></button></h3>
            <pre id="details">@item.Details</pre>
        </div>
    </div>
}

@if (item.Data.Any())
{
    <div class="card mb-3">
        <div class="card-body">
            <h3>Data:</h3>
            <div class="table-responsive">
                <table class="table table-hover mt-3">
                    <tbody>
                        @foreach (var pair in item.Data.OrderBy(p => p.Key))
                        {
                            <tr>
                                <th class="text-nowrap">@pair.Key</th>
                                <td>@pair.Value</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <h3>Request:</h3>
        <div class="table-responsive">
            <table class="table table-hover mt-3">
                <tbody>
                    @foreach (var pair in item.Request.OrderBy(p => p.Key))
                    {
                        <tr>
                            <th class="text-nowrap">@pair.Key</th>
                            <td>@pair.Value</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="mb-3">
    <a href="history:back" class="btn btn-secondary onback-allowclose"><i class="fas fa-solid fa-angle-left"></i> Back</a>
</div>
